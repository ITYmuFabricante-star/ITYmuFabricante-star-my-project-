/* General Styles */
* { box-sizing: border-box; margin: 0; padding: 0; font-family: sans-serif; }
body { line-height: 1.6; color: #333; background: #f4f4f4; }
section { padding: 40px 20px; text-align: center; }

/* Header - Using Flexbox */
.header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px;
    background: #fff;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    position: sticky;
    top: 0;
    z-index: 100;
}
.nav a { margin-left: 15px; text-decoration: none; color: #333; font-weight: bold; }

/* Hero Section */
.hero { background: #2c3e50; color: white; padding: 80px 20px; }

/* Gallery - Mobile First (Single Column) */
.gallery {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    max-width: 1200px;
    margin: auto;
}
.card { background: #fff; padding: 50px; border-radius: 8px; border: 1px solid #ddd; }

/* Footer */
.footer { background: #eee; padding: 20px; text-align: center; font-size: 0.9rem; }

/* --- RESPONSIVE BREAKPOINTS --- */

/* Tablet View (2 Columns) */
@media (min-width: 600px) {
    .gallery { grid-template-columns: repeat(2, 1fr); }
}

/* Desktop View (Multi-Column Layout) */
@media (min-width: 1024px) {
    .gallery { grid-template-columns: repeat(4, 1fr); }
    .about { padding: 80px 15%; } /* Better spacing for wide screens */
}
